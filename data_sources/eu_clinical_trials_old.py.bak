"""
EU Clinical Trials API Client
Fetches clinical trial data from https://euclinicaltrials.eu CTIS API for IPF
"""

import requests
import time
import logging
from typing import Dict, List, Optional, Any
from dataclasses import dataclass
import json

logger = logging.getLogger(__name__)

@dataclass
class EUClinicalTrial:
    """Data class for EU clinical trial information"""
    eudract_number: str
    title: str
    medical_condition: str
    trial_status: str
    trial_phase: Optional[str]
    trial_type: str
    sponsor: str
    start_date: Optional[str]
    completion_date: Optional[str]
    enrollment: Optional[int]
    therapeutic_area: str
    countries: List[str]
    url: str
    description: Optional[str]
    inclusion_criteria: Optional[str]
    exclusion_criteria: Optional[str]
    raw_trial: Optional[Dict[str, Any]] = None

class EUClinicalTrialsClient:
    """Client for fetching data from EU Clinical Trials CTIS API"""
    
    def __init__(self, base_url: str = "https://euclinicaltrials.eu", 
                 request_delay: float = 2.0, max_retries: int = 3):
        self.base_url = base_url
        self.api_search_url = f"{base_url}/ctis-public-api/search"
        self.api_retrieve_url = f"{base_url}/ctis-public-api/retrieve"
        self.request_delay = request_delay
        self.max_retries = max_retries
        self.session = requests.Session()
        self.session.headers.update({
            'User-Agent': 'Clinical-Trials-Data-Pipeline/1.0',
            'Content-Type': 'application/json',
            'Accept': 'application/json'
        })
    
    def _make_post_request(self, url: str, payload: Dict) -> Optional[Dict]:
        """Make HTTP POST request with retry logic"""
        for attempt in range(self.max_retries):
            try:
                response = self.session.post(url, json=payload, timeout=30)
                response.raise_for_status()
                
                # Rate limiting
                time.sleep(self.request_delay)
                
                return response.json()
                
            except requests.exceptions.RequestException as e:
                logger.warning(f"POST request attempt {attempt + 1} failed: {e}")
                if attempt == self.max_retries - 1:
                    logger.error(f"Failed to POST data after {self.max_retries} attempts")
                    return None
                time.sleep(2 ** attempt)
        
        return None
    
    def _make_get_request(self, url: str) -> Optional[Dict]:
        """Make HTTP GET request with retry logic"""
        for attempt in range(self.max_retries):
            try:
                response = self.session.get(url, timeout=30)
                response.raise_for_status()
                
                # Rate limiting
                time.sleep(self.request_delay)
                
                return response.json()
                
            except requests.exceptions.RequestException as e:
                logger.warning(f"GET request attempt {attempt + 1} failed: {e}")
                if attempt == self.max_retries - 1:
                    logger.error(f"Failed to GET data after {self.max_retries} attempts")
                    return None
                time.sleep(2 ** attempt)
        
        return None
    
    def search_ipf_trials(self, max_pages: int = 10) -> List[EUClinicalTrial]:
        """Search for IPF clinical trials"""
        trials = []
        
        logger.info(f"Searching EU Clinical Trials CTIS API for IPF studies")
        logger.info(f"Searching EU Clinical Trials for IPF studies")
        
        # Try to search for IPF trials
        search_params = {
            'q': 'Idiopathic Pulmonary Fibrosis',
            'search-type': 'simple'
        }
        
        response = self._make_request(self.search_url, search_params)
        if not response:
            logger.error("Failed to fetch search results")
            return trials
        
        # Parse the search results page
        soup = BeautifulSoup(response.text, 'html.parser')
        
        # Look for trial listings
        trial_links = self._extract_trial_links(soup)
        
        if not trial_links:
            logger.warning("No trial links found, trying alternative search")
            # Try alternative search terms
            alternative_terms = ["IPF", "pulmonary fibrosis", "lung fibrosis"]
            for term in alternative_terms:
                search_params['q'] = term
                response = self._make_request(self.search_url, search_params)
                if response:
                    soup = BeautifulSoup(response.text, 'html.parser')
                    trial_links = self._extract_trial_links(soup)
                    if trial_links:
                        break
        
        logger.info(f"Found {len(trial_links)} trial links")
        
        # Fetch details for each trial
        for i, link in enumerate(trial_links[:max_pages * 10]):  # Limit to prevent excessive requests
            if i % 10 == 0:
                logger.info(f"Processing trial {i + 1}/{len(trial_links)}")
            
            trial = self._fetch_trial_details(link)
            if trial and self._is_ipf_related(trial):
                trials.append(trial)
        
        logger.info(f"Successfully fetched {len(trials)} IPF-related EU trials")
        return trials
    
    def _extract_trial_links(self, soup: BeautifulSoup) -> List[str]:
        """Extract trial links from search results page"""
        links = []
        
        # Look for common patterns in trial listings
        selectors = [
            'a[href*="trial"]',
            'a[href*="EudraCT"]',
            '.trial-title a',
            '.search-result a',
            'tr a[href*="clinical"]'
        ]
        
        for selector in selectors:
            elements = soup.select(selector)
            for element in elements:
                href = element.get('href')
                if href and 'trial' in href.lower():
                    # Properly construct full URL
                    if href.startswith('http'):
                        full_url = href
                    elif href.startswith('/'):
                        full_url = f"{self.base_url}{href}"
                    else:
                        # Relative path without leading slash
                        full_url = f"{self.base_url}/{href}"
                    
                    # Validate URL before adding
                    if full_url.startswith('http') and '..' not in full_url and full_url not in links:
                        links.append(full_url)
        
        return links
    
    def _fetch_trial_details(self, trial_url: str) -> Optional[EUClinicalTrial]:
        """Fetch detailed information for a specific trial"""
        response = self._make_request(trial_url)
        if not response:
            return None
        
        soup = BeautifulSoup(response.text, 'html.parser')
        
        try:
            return self._parse_trial_page(soup, trial_url)
        except Exception as e:
            logger.error(f"Error parsing trial page {trial_url}: {e}")
            return None
    
    def _parse_trial_page(self, soup: BeautifulSoup, url: str) -> Optional[EUClinicalTrial]:
        """Parse individual trial page"""
        try:
            # Extract EudraCT number
            eudract_number = self._extract_text(soup, [
                '[data-field="eudract"]',
                '.eudract-number',
                'th:contains("EudraCT") + td',
                'td:contains("EudraCT")'
            ])
            
            if not eudract_number:
                # Try to extract from URL
                eudract_match = re.search(r'(\d{4}-\d{6}-\d{2})', url)
                eudract_number = eudract_match.group(1) if eudract_match else ''
            
            # Extract title
            title = self._extract_text(soup, [
                'h1',
                '.trial-title',
                '.title',
                'th:contains("Title") + td'
            ])
            
            # Extract medical condition
            medical_condition = self._extract_text(soup, [
                'th:contains("Condition") + td',
                'th:contains("Medical Condition") + td',
                '.condition',
                '.medical-condition'
            ])
            
            # Extract trial status
            trial_status = self._extract_text(soup, [
                'th:contains("Status") + td',
                '.status',
                '.trial-status'
            ])
            
            # Extract trial phase
            trial_phase = self._extract_text(soup, [
                'th:contains("Phase") + td',
                '.phase',
                '.trial-phase'
            ])
            
            # Extract sponsor
            sponsor = self._extract_text(soup, [
                'th:contains("Sponsor") + td',
                '.sponsor',
                '.trial-sponsor'
            ])
            
            # Extract dates
            start_date = self._extract_text(soup, [
                'th:contains("Start Date") + td',
                'th:contains("Start") + td',
                '.start-date'
            ])
            
            completion_date = self._extract_text(soup, [
                'th:contains("Completion") + td',
                'th:contains("End Date") + td',
                '.completion-date'
            ])
            
            # Extract enrollment
            enrollment_text = self._extract_text(soup, [
                'th:contains("Enrollment") + td',
                'th:contains("Subjects") + td',
                '.enrollment'
            ])
            enrollment = self._parse_enrollment(enrollment_text)
            
            # Extract countries
            countries_text = self._extract_text(soup, [
                'th:contains("Countries") + td',
                'th:contains("Country") + td',
                '.countries'
            ])
            countries = self._parse_countries(countries_text)
            
            # Extract description
            description = self._extract_text(soup, [
                '.description',
                '.summary',
                'th:contains("Summary") + td',
                'div[class*="description"]'
            ])
            
            # Extract inclusion/exclusion criteria
            inclusion_criteria = self._extract_text(soup, [
                'th:contains("Inclusion") + td',
                '.inclusion-criteria',
                '.inclusion'
            ])
            
            exclusion_criteria = self._extract_text(soup, [
                'th:contains("Exclusion") + td',
                '.exclusion-criteria',
                '.exclusion'
            ])
            
            return EUClinicalTrial(
                eudract_number=eudract_number or '',
                title=title or '',
                medical_condition=medical_condition or '',
                trial_status=trial_status or '',
                trial_phase=trial_phase,
                trial_type='Interventional',  # Default assumption
                sponsor=sponsor or '',
                start_date=start_date,
                completion_date=completion_date,
                enrollment=enrollment,
                therapeutic_area='Respiratory',  # Default for IPF
                countries=countries,
                url=url,
                description=description,
                inclusion_criteria=inclusion_criteria,
                exclusion_criteria=exclusion_criteria
            )
            
        except Exception as e:
            logger.error(f"Error parsing trial page: {e}")
            return None
    
    def _extract_text(self, soup: BeautifulSoup, selectors: List[str]) -> Optional[str]:
        """Extract text using multiple selector attempts"""
        for selector in selectors:
            try:
                element = soup.select_one(selector)
                if element:
                    text = element.get_text(strip=True)
                    if text:
                        return text
            except:
                continue
        return None
    
    def _parse_enrollment(self, enrollment_text: Optional[str]) -> Optional[int]:
        """Parse enrollment count from text"""
        if not enrollment_text:
            return None
        
        # Extract numbers from text
        numbers = re.findall(r'\d+', enrollment_text.replace(',', ''))
        if numbers:
            return int(numbers[0])
        
        return None
    
    def _parse_countries(self, countries_text: Optional[str]) -> List[str]:
        """Parse countries from text"""
        if not countries_text:
            return []
        
        # Split by common delimiters
        countries = re.split(r'[,;]\s*', countries_text)
        return [country.strip() for country in countries if country.strip()]
    
    def _is_ipf_related(self, trial: EUClinicalTrial) -> bool:
        """Check if trial is IPF-related"""
        ipf_keywords = [
            'idiopathic pulmonary fibrosis',
            'ipf',
            'pulmonary fibrosis',
            'lung fibrosis',
            'interstitial lung disease',
            'ild'
        ]
        
        text_to_check = f"{trial.title} {trial.medical_condition} {trial.description}".lower()
        
        return any(keyword in text_to_check for keyword in ipf_keywords)

if __name__ == "__main__":
    # Example usage
    logging.basicConfig(level=logging.INFO)
    
    client = EUClinicalTrialsClient()
    trials = client.search_ipf_trials(max_pages=2)
    
    for trial in trials[:3]:
        print(f"EudraCT: {trial.eudract_number}")
        print(f"Title: {trial.title}")
        print(f"Status: {trial.trial_status}")
        print(f"Countries: {', '.join(trial.countries)}")
        print("-" * 50)
